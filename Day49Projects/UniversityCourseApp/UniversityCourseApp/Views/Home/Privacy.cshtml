@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="content-card privacy-card">
    <span class="eyebrow">Privacy</span>
    <h1 class="section-title">@ViewData["Title"]</h1>
    <p class="section-copy">
        This demo application uses in-memory academic data for display purposes and does not persist personal information.
    </p>
    <p class="section-copy">
        If you later connect it to a database, this page is the right place to describe storage, access control, and retention clearly.
    </p>
</section>
