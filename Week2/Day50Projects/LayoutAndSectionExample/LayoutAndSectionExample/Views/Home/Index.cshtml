@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card d-flex align-items-center">
        <div class="stat-icon me-3">
            <i class="fas fa-users"></i>
        </div>
        <div>
            <div class="stat-label">Total Employees</div>
            <div class="stat-value">@ViewBag.TotalEmployees</div>
        </div>
    </div>
    
    <div class="stat-card d-flex align-items-center">
        <div class="stat-icon me-3">
            <i class="fas fa-building"></i>
        </div>
        <div>
            <div class="stat-label">Departments</div>
            <div class="stat-value">@ViewBag.TotalDepartments</div>
        </div>
    </div>
    
    <div class="stat-card d-flex align-items-center">
        <div class="stat-icon me-3">
            <i class="fas fa-user-check"></i>
        </div>
        <div>
            <div class="stat-label">Active Employees</div>
            <div class="stat-value">@ViewBag.ActiveEmployees</div>
        </div>
    </div>
    
    <div class="stat-card d-flex align-items-center">
        <div class="stat-icon me-3">
            <i class="fas fa-rupee-sign"></i>
        </div>
        <div>
            <div class="stat-label">Avg Salary</div>
            <div class="stat-value">₹@ViewBag.AverageSalary</div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="row mt-4">
    <div class="col-md-6">
        <div class="card card-hover">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">
                    <i class="fas fa-user-plus me-2 text-primary"></i>
                    Recent Employees
                </h5>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fas fa-user-circle me-2 text-muted"></i>
                            John Doe
                        </div>
                        <span class="badge bg-success">New</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fas fa-user-circle me-2 text-muted"></i>
                            Jane Smith
                        </div>
                        <span class="badge bg-success">New</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card card-hover">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">
                    <i class="fas fa-chart-pie me-2 text-primary"></i>
                    Department Distribution
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>IT Department</span>
                        <span>45%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-primary" style="width: 45%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>HR</span>
                        <span>20%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 20%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Finance</span>
                        <span>25%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-warning" style="width: 25%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mt-4">
    <div class="col-12">
        <div class="d-flex gap-2">
            <a href="#" class="btn btn-gradient">
                <i class="fas fa-plus me-2"></i>Add Employee
            </a>
            <a href="#" class="btn btn-gradient">
                <i class="fas fa-plus me-2"></i>Add Department
            </a>
            <a href="#" class="btn btn-gradient">
                <i class="fas fa-download me-2"></i>Export Report
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Page specific scripts
        console.log('Dashboard loaded');
    </script>
}