@model IEnumerable<MVCExampleDemo.Models.Dept>
@{
    ViewData["Title"] = "collectionOfDept";
}

<h1>collectionOfDept</h1>


<table border="1" cellpadding="5" cellspacing="5">
    <thead>
        <tr>
            <th>DeptId</th>
            <th>DeptName</th>
            <th>Action</th>

        </tr>
    </thead>

    <tbody>
        @foreach (var dept in Model)
        {
            <tr>
                <td>@dept.DeptId</td>
                <td>@dept.DeptName</td>
                <td><a href="/Home/EmpsInDept?deptId=@dept.DeptId">EmpsInDept</a></td>
            </tr>
        }
    </tbody>


</table>